rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── User document & all sub-collections ─────────────────────────────────
    // A user can only read or write their own subtree.
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // Family member profiles
      match /family/{memberId} {
        allow read, write: if isOwner(uid);
      }

      // Weekly plans (incl. nested grocery sub-collection)
      match /plans/{weekId} {
        allow read, write: if isOwner(uid);

        match /grocery/{document=**} {
          allow read, write: if isOwner(uid);
        }
      }

      // Per-slot feedback
      match /feedback/{slotRef} {
        allow read, write: if isOwner(uid);
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
