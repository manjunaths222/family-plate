# ============================================================
# FamilyPlate — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to source control.
# ============================================================

# ── Firebase (client-side — NEXT_PUBLIC_ prefix required) ───
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server-side only) ───────────────────
# Download a service-account JSON from Firebase Console →
# Project Settings → Service Accounts → Generate new private key.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the private key exactly as-is (including \n escapes).
FIREBASE_ADMIN_PRIVATE_KEY=

# ── AI Provider ─────────────────────────────────────────────
# Set AI_PROVIDER to: anthropic | openai | gemini
AI_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (only needed if AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini (only needed if AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ── Cron Protection ─────────────────────────────────────────
# A long random string. Set the same value in Vercel env and
# in the Vercel Cron request header (automatically injected
# by Vercel when you set CRON_SECRET).
CRON_SECRET=

# ── Optional: Vercel KV (Redis) for cron locking / caching ──
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── App URL (needed for absolute links in emails/notifs) ─────
NEXT_PUBLIC_APP_URL=http://localhost:3000
